{
  "name": "deepseek-opt",
  "version": "1.0.0",
  "description": "Token optimizer for DeepSeek v4 Pro — reduces context window usage through smart file prediction, prompt compression, and adaptive learning",
  "type": "module",
  "main": "./dist/index.js",
  "bin": {
    "deepseek-opt": "./dist/index.js",
    "ds": "./dist/index.js"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/ tests/",
    "format": "prettier --write src/ tests/"
  },
  "keywords": ["deepseek", "token", "optimizer", "cli", "context-window"],
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "chalk": "^5.4.1",
    "commander": "^13.1.0",
    "zod": "^3.24.2",
    "gpt-tokenizer": "^2.9.0"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "eslint": "^9.22.0",
    "prettier": "^3.5.3",
    "tsup": "^8.4.0",
    "typescript": "^5.8.2",
    "vitest": "^3.0.9"
  }
}
